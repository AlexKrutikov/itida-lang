/* Демонстрационный файл языка Вычислителя Айтида
   Показывает подсветку синтаксиса и основные конструкции */

// Загрузка курсов валют с сайта ЦБ РФ
// Информация поступает в виде XML файла

ФУНКЦИЯ ЗагрузитьКурсыВалют( КодВалюты, Дней )
{
    Соединение = СокетСоединить( "www.cbr.ru", 80, true );

    СокетПередать( Соединение,
        "GET /scripts/XML_dynamic.asp?date_req1=" +
        DTOC( ДОБАВИТЬДНИ( ДАТАВРЕМЯ( ), - Дней ), 4 ) +
        "&date_req2=" + DTOC( ДАТАВРЕМЯ( ), 4 ) +
        "&VAL_NM_RQ=" + КодВалюты +
        " HTTP/1.1" + CHR( 13 ) + CHR( 10 ) +
        "Host: www.cbr.ru" + CHR( 13 ) + CHR( 10 ) +
        CHR( 13 ) + CHR( 10 ) );

    Ответ = СокетПолучить( Соединение, CHR( 13 ) + CHR( 10 ) + CHR( 13 ) + CHR( 10 ) );

    IF ( AT( Ответ, 'Content-Length:' ) > 0 )
    {
        Длина = VAL( SUBSTR( Ответ, AT( Ответ, 'Content-Length:' ) + 15 ) );
        Ответ = СокетПолучить( Соединение, Длина );
    }
    ELSE
    {
        КОДРЕЗУЛЬТАТА = false;
        ОПИСАНИЕРЕЗУЛЬТАТА = "Ошибка чтения файла с сайта ЦБ РФ. " + _ERRORDESCRIPTION;
        RETURN false;
    }

    СокетЗакрыть( Соединение );
    RETURN Ответ;
}

/* Функция обработки полученных данных */
ФУНКЦИЯ LOCAL ОбработатьКурсы( КодВалюты )
{
    Ответ = ЗагрузитьКурсыВалют( КодВалюты, 7 );

    IF ( TYPE( "Ответ" ) != "C" OR EMPTY( Ответ ) )
        RETURN false;

    ИмяФайла = УникальноеИмя( );
    Файл = ФайлСоздать( ИмяФайла );
    ФайлЗаписать( Файл, Ответ );
    ФайлЗакрыть( Файл );

    ДобавитьКонтекст( "SET FMTONLY ON
        SELECT GETDATE() AS date, CONVERT( float, 0 ) AS nominal,
        CONVERT( float, 0 ) AS value SET FMTONLY OFF", "Курсы" );

    Загрузить( "Курсы", "XML", ИмяФайла, "Record" );

    // Проверяем обратный курс в справочнике валют
    ОбратныйКурс = ЗАПРОС( "SELECT f_rev FROM sprcur WHERE code = '" + КодВалюты + "'" );

    ВыбратьКонтекст( "Курсы" );
    ПерейтиВНачало( "Курсы" );

    WHILE ( !КонецКонтекста( "Курсы" ) )
    {
        IF ( Курсы.Value <> 0 )
        {
            ЗАПРОС( "DELETE FROM sprrate
                WHERE DATEDIFF( day, date, '" + Курсы.date + "' ) = 0
                AND code = '" + КодВалюты + "'" );

            ЗАПРОС( "INSERT INTO sprrate ( code, date, rate )
                VALUES ( '" + КодВалюты + "', '" + Курсы.date + "', " +
                STR( ЕСЛИ( ОбратныйКурс, 1 / Курсы.Value, Курсы.Value ), 20, 8 ) + ")" );
        }

        Пропустить( 1, "Курсы" );
    }

    УдалитьКонтекст( "Курсы" );
    ФайлУдалить( ИмяФайла );
    RETURN true;
}

// Основной скрипт
ОбработатьКурсы( "USD" );
ОбработатьКурсы( "EUR" );

