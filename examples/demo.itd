// Пример: создание документа с SQL
ФУНКЦИЯ СоздатьДокумент( )
{
    СписокУчетов = "";

    ДобавитьКонтекст( "SELECT account_ FROM specviewpoints_def
        WHERE code= '" + _ТОЧКАЗРЕНИЯ + "' AND objtype= 'DOC'
        AND objcode= '009' AND t_concept = ''", "МоделиУчета" );

    WHILE ( !КонецКонтекста( "МоделиУчета" ) )
    {
        СписокУчетов += МоделиУчета.account_;
        Пропустить( 1, "МоделиУчета" );
    }

    УдалитьКонтекст( "МоделиУчета" );
    СписокУчетов = ALLTRIM( СписокУчетов );

    TRY
    {
        ЗАПРОС( "BEGIN TRANSACTION" );

        ДобавитьКонтекст( "EXECUTE sp_insertdoc '009', '', '" +
            ДАТАВРЕМЯ( ) + "', '', '" + @Фирма + "', '', 'RUB', '',
            '" + СписокУчетов + "', '" + _ТОЧКАЗРЕНИЯ + "', 0, '001'", "ident" );

        ЗАПРОС( "IF @@TRANCOUNT > 0 COMMIT TRANSACTION" );

        ОтправитьСообщение( _ГЛАВНОЕОКНОПРИЛОЖЕНИЯ,
            _СООБЩЕНИЕ_ПРОСМОТРДОКУМЕНТА, "009", ident.ident );

        УдалитьКонтекст( "ident" );
    }
    CATCH
    {
        ЗАПРОС( "IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION" );
        Сообщение( "Ошибка при создании документа", "Ошибка" );
        RETURN false;
    }

    RETURN true;
}

