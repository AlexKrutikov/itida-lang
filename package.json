{
  "name": "itida-lang",
  "displayName": "Itida Lang",
  "description": "Syntax highlighting and IntelliSense for Itida language",
  "version": "0.0.1",
  "publisher": "itida",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "itida",
        "aliases": [
          "Itida",
          "itida",
          "Айтида"
        ],
        "extensions": [
          ".itd"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./img/itida-icon-light.png",
          "dark": "./img/itida-icon-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "itida",
        "scopeName": "source.itida",
        "path": "./syntaxes/itida.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "itida",
        "path": "./snippets/itida.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0"
  }
}