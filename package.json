{
  "name": "itida-lang",
  "displayName": "Itida Lang",
  "description": "Syntax highlighting for Itida lang",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "itida",
        "aliases": [
          "itida",
          "itida"
        ],
        "extensions": [
          ".itd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "itida",
        "scopeName": "source.itida",
        "path": "./syntaxes/itida.tmLanguage.json"
      }
    ]
  }
}