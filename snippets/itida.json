{
    "IF": {
        "prefix": ["IF", "if"],
        "body": [
            "IF ( ${1:условие} )",
            "{",
            "\t$0",
            "}"
        ],
        "description": "Условный оператор IF"
    },
    "IF...ELSE": {
        "prefix": ["IFELSE", "ifelse"],
        "body": [
            "IF ( ${1:условие} )",
            "{",
            "\t$2",
            "}",
            "ELSE",
            "{",
            "\t$0",
            "}"
        ],
        "description": "Условный оператор IF...ELSE"
    },
    "WHILE": {
        "prefix": ["WHILE", "while"],
        "body": [
            "WHILE ( ${1:условие} )",
            "{",
            "\t$0",
            "}"
        ],
        "description": "Цикл WHILE"
    },
    "TRY...CATCH": {
        "prefix": ["TRY", "try"],
        "body": [
            "TRY",
            "{",
            "\t$1",
            "}",
            "CATCH",
            "{",
            "\t$0",
            "}"
        ],
        "description": "Блок TRY...CATCH"
    },
    "FUNCTION": {
        "prefix": ["FUNCTION", "ФУНКЦИЯ", "func"],
        "body": [
            "ФУНКЦИЯ ${1:ИмяФункции}( ${2:параметры} )",
            "{",
            "\t$0",
            "\tRETURN ${3:результат};",
            "}"
        ],
        "description": "Объявление функции"
    },
    "FUNCTION LOCAL": {
        "prefix": ["FUNCTIONLOCAL", "funclocal"],
        "body": [
            "ФУНКЦИЯ LOCAL ${1:ИмяФункции}( ${2:параметры} )",
            "{",
            "\t$0",
            "\tRETURN ${3:результат};",
            "}"
        ],
        "description": "Объявление локальной функции"
    },
    "ЗАПРОС": {
        "prefix": ["ЗАПРОС", "QUERY", "query"],
        "body": "ЗАПРОС( \"${1:SELECT * FROM table WHERE condition}\" )",
        "description": "Выполнение SQL запроса"
    },
    "ДобавитьКонтекст": {
        "prefix": ["ДобавитьКонтекст", "ADDCONTEXT", "addctx"],
        "body": [
            "ДобавитьКонтекст( \"${1:SELECT * FROM table}\", \"${2:ИмяКонтекста}\" );"
        ],
        "description": "Добавить контекст из SQL запроса"
    },
    "WHILE КонтекстЦикл": {
        "prefix": ["whilectx", "циклконтекст"],
        "body": [
            "ВыбратьКонтекст( \"${1:Контекст}\" );",
            "ПерейтиВНачало( \"${1:Контекст}\" );",
            "",
            "WHILE ( !КонецКонтекста( \"${1:Контекст}\" ) )",
            "{",
            "\t$0",
            "\tПропустить( 1, \"${1:Контекст}\" );",
            "}",
            "",
            "УдалитьКонтекст( \"${1:Контекст}\" );"
        ],
        "description": "Цикл по контексту (типовой паттерн)"
    },
    "PUBLIC": {
        "prefix": ["PUBLIC", "public"],
        "body": "PUBLIC ${1:ИмяПеременной} = ${2:значение};",
        "description": "Объявление публичной переменной"
    },
    "LOCAL": {
        "prefix": ["LOCAL", "local"],
        "body": "LOCAL ${1:ИмяПеременной} = ${2:значение};",
        "description": "Объявление локальной переменной"
    },
    "Сообщение": {
        "prefix": ["Сообщение", "msg"],
        "body": "Сообщение( \"${1:текст сообщения}\", \"${2:заголовок сообщения}\" );",
        "description": "Вывод сообщения пользователю"
    },
    "ЕСЛИ/IIF": {
        "prefix": ["ЕСЛИ", "IIF", "iif"],
        "body": "ЕСЛИ( ${1:условие}, ${2:значениеДа}, ${3:значениеНет} )",
        "description": "Тернарная функция ЕСЛИ/IIF"
    },
    "Дата литерал": {
        "prefix": ["дата", "date{"],
        "body": "{${1:01.01.2025}}",
        "description": "Константа даты {ДД.ММ.ГГГГ}"
    },
    "СокетСоединить": {
        "prefix": ["СокетСоединить", "socket"],
        "body": [
            "Соединение = СокетСоединить( \"${1:host}\", ${2:80}, ${3:true} );",
            "СокетПередать( Соединение, ${4:данные} );",
            "Ответ = СокетПолучить( Соединение );",
            "СокетЗакрыть( Соединение );"
        ],
        "description": "Работа с сокетом (подключение, отправка, получение, закрытие)"
    },
    "СФОРМИРОВАТЬ_JSON": {
        "prefix": ["GETJSON", "json"],
        "body": "СФОРМИРОВАТЬ_JSON( \"<ЗАПРОС>'${1:SELECT * FROM table}'</ЗАПРОС><ТЭГЗАГОЛОВКА>${2:Data}</ТЭГЗАГОЛОВКА><ТЭГСТРОКИ>${3:Row}</ТЭГСТРОКИ>\" )",
        "description": "Формирование JSON из SQL запроса"
    }
}